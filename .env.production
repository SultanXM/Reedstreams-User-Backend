# JWT Secret (generate a random string, at least 32 chars)
JWT_SECRET=CHANGE_THIS_TO_RANDOM_SECURE_SECRET_KEY

# Optional: Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
